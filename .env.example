# Copy to .env and fill in. .env is gitignored.

# Required for FRED macro data (Stage 2)
FRED_API_KEY=

# SEC EDGAR requires a contact email in the User-Agent; no key.
SEC_USER_AGENT=weekly-strategy your.email@example.com

# Reddit public JSON endpoints; no key, just a polite UA.
REDDIT_USER_AGENT=weekly-strategy/0.1 by your.email@example.com

# LLM: we use `claude` CLI in headless mode against the user's subscription.
# Override CLAUDE_BIN only if the binary isn't on PATH.
# CLAUDE_BIN=/home/you/.local/bin/claude
#
# Do NOT set ANTHROPIC_API_KEY here -- if set, claude switches to API billing
# and bypasses your subscription quota. The subprocess wrapper strips it
# defensively, but keeping it out of .env is the safer default.
